<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MemoFlow" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/accent_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/screen_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Widget.MemoFlow.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/card_stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.MemoFlow.PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.MemoFlow.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/card_stroke</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.MemoFlow.DangerButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/danger</item>
        <item name="android:textColor">@color/danger</item>
    </style>
</resources>
